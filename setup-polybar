sleep 5

clear

############################################################################################
#################################### UPDATE BASE SYSTEM ####################################
############################################################################################
    clear
    # Detect package manager and update system
    
    if command -v pacman >/dev/null 2>&1; then
      echo "Arch-based system detected. Updating with pacman..." 2>&1 | tee -a $LOG
      echo "Please enter sudo password if requested..."
      sudo pacman -Syu --noconfirm 2>&1 | tee -a $LOG
      sudo pacman -S --noconfirm polybar mpd mpc ncmpcpp rofi 2>&1 | tee -a $LOG
      sleep 5
    
    elif command -v apt-get >/dev/null 2>&1; then
      echo "Debian/Ubuntu-based system detected. Updating with apt-get..." 2>&1 | tee -a $LOG
      echo "Please enter sudo password if requested..."
      #sudo apt-get update && sudo apt-get upgrade -y 2>&1 | tee -a $LOG
      sudo apt-get install polybar mpd mpc ncmpcpp rofi -y 2>&1 | tee -a $LOG
      sleep 5
    
    else
      echo "No supported package manager found."
      exit 1
    fi

    ############### Install Configs for Polybar and Apps
    sudo cp -r $INSTALL_PATH/fonts/jaxtech /usr/share/fonts/ 2>&1 | tee -a $LOG
    sudo cp $INSTALL_PATH/scripts/* /usr/local/bin/ 2>&1 | tee -a $LOG
    [ ! -d ~/.config/mpd ] && mkdir -p ~/.config/mpd 2>&1 | tee -a $LOG
    [ ! -d ~/.config/ncmpcpp ] && mkdir -p ~/.config/ncmpcpp 2>&1 | tee -a $LOG
    [ ! -d ~/.config/polybar ] && mkdir -p ~/.config/polybar 2>&1 | tee -a $LOG
    [ ! -d ~/.config/rofi ] && mkdir -p ~/.config/rofi 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/.config/autostart/mpd.desktop ~/.config/autostart/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/.config/autostart/polybar.desktop ~/.config/autostart/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/.config/mpd/* ~/.config/mpd/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/.config/ncmpcpp/* ~/.config/ncmpcpp/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/.config/polybar/* ~/.config/polybar/ 2>&1 | tee -a $LOG
    cp -r $INSTALL_PATH/.config/rofi/* ~/.config/rofi/ 2>&1 | tee -a $LOG
    cp -r $INSTALL_PATH/music/* ~/Music/ 2>&1 | tee -a $LOG
    cp ~/.config/polybar/config.ini ~/.config/polybar/
    touch ~/.config/mpd/mpd.db 2>&1 | tee -a $LOG
    touch ~/.config/mpd/mpd.log 2>&1 | tee -a $LOG
    touch ~/.config/mpd/mpd.pid 2>&1 | tee -a $LOG
    systemctl --user enable mpd.service
    sleep 5

